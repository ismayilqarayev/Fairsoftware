#!/usr/bin/env pwsh
try {
    # Hangi dalda olduğumuzu öğren
    $branch = git rev-parse --abbrev-ref HEAD

    # Korumalı ana dallara otomatik push yapılmasını engelle (örnek: main, master)
    $protected = @('main','master')
    if ($protected -contains $branch) {
        Write-Host "Auto-push devre dışı bırakıldı: korunan dal '$branch'"
        exit 0
    }

    Write-Host "Auto-push: pushing branch $branch"
    git push
    if ($LASTEXITCODE -ne 0) {
        Write-Error "git push başarısız oldu. Kod: $LASTEXITCODE"
        exit $LASTEXITCODE
    }
} catch {
    Write-Error "Auto-push sırasında hata: $_"
    exit 1
}