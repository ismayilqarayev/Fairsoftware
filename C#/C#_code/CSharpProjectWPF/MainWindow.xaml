<Window x:Class="CSharpProjectWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Şəxs Məlumatı Toplama" Height="700" Width="600" WindowStartupLocation="CenterScreen">
    <Grid Background="#F5F5F5">
        <StackPanel Margin="20">
            <!-- Başlıq -->
            <TextBlock Text="Şəxs Məlumatlarını Daxil Edin" 
                       FontSize="24" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>
            
            <!-- Neçə nəfər girişi -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <TextBlock Text="Neçə nəfər üçün məlumat daxil etmək istəyirsiniz:" 
                           VerticalAlignment="Center" Width="350" FontSize="14"/>
                <TextBox x:Name="PersonCountTextBox" Width="60" Padding="8" FontSize="14"/>
                <Button Content="Başla" Click="StartButton_Click" Margin="10,0,0,0" 
                        Padding="15,8" FontSize="14" Background="#4CAF50" Foreground="White" 
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <!-- Məlumatların daxiletmə bölməsi -->
            <Border x:Name="InputPanel" Visibility="Collapsed" BorderBrush="#DDD" 
                    BorderThickness="1" Padding="15" Margin="0,20,0,0" Background="White">
                <StackPanel>
                    <!-- Neçənci şəxs -->
                    <TextBlock x:Name="PersonNumberLabel" FontSize="16" FontWeight="Bold" 
                               Foreground="#2196F3" Margin="0,0,0,15"/>

                    <!-- Ad -->
                    <TextBlock Text="Ad:" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="AdTextBox" Padding="10" Margin="0,0,0,10" FontSize="12"/>

                    <!-- Ata adı -->
                    <TextBlock Text="Ata adı:" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="AtaAdiTextBox" Padding="10" Margin="0,0,0,10" FontSize="12"/>

                    <!-- Email -->
                    <TextBlock Text="E-poçt ünvanı:" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="EmailTextBox" Padding="10" Margin="0,0,0,10" FontSize="12"/>

                    <!-- Telefon -->
                    <TextBlock Text="Telefon nömrəsi (10 rəqəm):" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="TelefonnomresiTextBox" Padding="10" Margin="0,0,0,10" FontSize="12"/>

                    <!-- Yaş -->
                    <TextBlock Text="Yaş:" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="YasTextBox" Padding="10" Margin="0,0,0,15" FontSize="12"/>

                    <!-- Düymələr -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Sonrakı" Click="NextButton_Click" 
                                Padding="15,8" FontSize="12" Background="#2196F3" 
                                Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
                        <Button Content="Bitir" Click="FinishButton_Click" 
                                Padding="15,8" FontSize="12" Background="#FF9800" 
                                Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Nəticələr bölməsi -->
            <Border x:Name="ResultsPanel" Visibility="Collapsed" BorderBrush="#DDD" 
                    BorderThickness="1" Padding="15" Margin="0,20,0,0" Background="White">
                <StackPanel>
                    <TextBlock Text="Daxil Edilən Məlumatlar" FontSize="16" FontWeight="Bold" 
                               Foreground="#2196F3" Margin="0,0,0,15"/>
                    <ListBox x:Name="ResultListBox" MinHeight="200" Padding="5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Padding="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Button Content="Yenidən Başla" Click="RestartButton_Click" 
                            Padding="15,8" FontSize="12" Background="#4CAF50" 
                            Foreground="White" BorderThickness="0" Margin="0,15,0,0"
                            HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <!-- Xəta mesajları -->
            <TextBlock x:Name="ErrorMessageBlock" Foreground="#F44336" 
                       Margin="0,15,0,0" TextWrapping="Wrap" FontSize="12"/>
        </StackPanel>
    </Grid>
</Window>
